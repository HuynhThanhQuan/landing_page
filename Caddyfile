# Curious Machine landing site (Next.js static export) — served by the same Caddy
# instance running n8n + portfolio. Append this block to ~/services/caddy/Caddyfile
# and `docker exec caddy caddy reload --config /etc/caddy/Caddyfile`.
#
# Requires the host directory `~/sites/curious-machine/` to be present
# (auto-created by deploy.sh).

curiousmachine.152-42-201-32.sslip.io {
	root * /srv/curious-machine
	encode zstd gzip

	# Next.js export uses trailingSlash: true; try directory index then /index.html.
	try_files {path} {path}/ {path}/index.html

	file_server

	# Hashed Next.js assets — safe to cache aggressively.
	@nextStatic path /_next/static/*
	header @nextStatic Cache-Control "public, max-age=31536000, immutable"

	# Other static media.
	@assets {
		path *.css *.js *.jpg *.jpeg *.png *.webp *.svg *.ico *.woff *.woff2 *.avif
	}
	header @assets Cache-Control "public, max-age=2592000"

	# HTML should always revalidate.
	@html {
		path *.html /
	}
	header @html Cache-Control "no-cache"

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		-Server
	}

	handle_errors {
		@404 expression {http.error.status_code} == 404
		rewrite @404 /404.html
		file_server
	}
}
